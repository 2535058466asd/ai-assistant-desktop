# ==========================================
# 启源 AI - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ==========================================

# 豆包聊天 API 密钥
VITE_DOUBAO_API_KEY=

# 豆包聊天模型
VITE_DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# 默认模型 Provider：doubao / openai-compatible / mimo
VITE_MODEL_PROVIDER=doubao

# OpenAI-compatible Provider（DeepSeek/OpenRouter/本地兼容服务等）
VITE_OPENAI_COMPATIBLE_BASE_URL=
VITE_OPENAI_COMPATIBLE_API_KEY=
VITE_OPENAI_COMPATIBLE_MODEL=

# 小米 MiMo Provider（等拿到官方 API 文档后填写）
VITE_MIMO_BASE_URL=
VITE_MIMO_API_KEY=
VITE_MIMO_MODEL=

# 日志级别：debug / info / warn / error
LOG_LEVEL=debug

# 豆包图片识别 API 密钥（可与聊天密钥相同）
VITE_DOUBAO_VISION_API_KEY=

# 豆包图片识别模型
VITE_DOUBAO_VISION_MODEL=doubao-1-5-vision-pro-250328

# 火山引擎语音服务 App ID
VITE_VOLCENGINE_APP_ID=

# 火山引擎语音服务 Access Token
VITE_VOLCENGINE_ACCESS_TOKEN=
