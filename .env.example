# ==========================================
# 启源 AI - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ==========================================

# 豆包聊天 API 密钥
VITE_DOUBAO_API_KEY=

# 豆包聊天模型
VITE_DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# 豆包图片识别 API 密钥（可与聊天密钥相同）
VITE_DOUBAO_VISION_API_KEY=

# 豆包图片识别模型
VITE_DOUBAO_VISION_MODEL=doubao-1-5-vision-pro-250328

# 火山引擎语音服务 App ID
VITE_VOLCENGINE_APP_ID=

# 火山引擎语音服务 Access Token
VITE_VOLCENGINE_ACCESS_TOKEN=
