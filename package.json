{
  "name": "ai-assistant-desktop",
  "version": "1.0.0",
  "description": "Desktop AI Assistant with STT/TTS and LLM",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite --open false",
    "build": "tsc && vite build",
    "build:node": "tsc -p tsconfig.node.json",
    "electron:dev": "npm run build:node && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && set NODE_ENV=development && electron .\"",
    "electron:build": "npm run build:node && npm run build && electron-builder"
  },
  "keywords": [
    "ai",
    "assistant",
    "electron",
    "stt",
    "tts"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@babel/types": "^7.29.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.6",
    "chromadb": "^3.4.3",
    "dompurify": "^3.1.6",
    "edge-tts": "^1.0.1",
    "mammoth": "^1.12.0",
    "node-whisper": "^2024.11.13",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^1.0.1",
    "remark-gfm": "^4.0.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "turndown": "^7.2.4",
    "univoice": "^0.7.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^33.3.1",
    "electron-builder": "^24.9.0",
    "electron-reloader": "^1.2.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nova.desktop",
    "productName": "Nova",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "dir"
    }
  }
}
