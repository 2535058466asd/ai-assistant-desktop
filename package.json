{
  "name": "nova",
  "version": "1.0.0",
  "description": "Desktop AI Agent workspace with tools, memory, RAG, voice, and observability",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:node": "tsc -p tsconfig.node.json",
    "check": "npm run build",
    "smoke:web": "node scripts/smoke-web.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "npm run build:node && concurrently \"npm run dev\" \"wait-on http://localhost:5173 && set NODE_ENV=development && electron .\"",
    "electron:build": "npm run build:node && npm run build && electron-builder"
  },
  "keywords": [
    "ai",
    "assistant",
    "electron",
    "stt",
    "tts"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "dompurify": "^3.1.6",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.0",
    "remark-gfm": "^4.0.1",
    "sqlite": "^5.1.1",
    "sqlite-vec": "^0.1.9",
    "sqlite3": "^6.0.1",
    "turndown": "^7.2.4",
    "uuid": "^9.0.1",
    "ws": "^8.20.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^33.3.1",
    "electron-builder": "^24.9.0",
    "electron-reloader": "^1.2.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.nova.desktop",
    "productName": "Nova",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "dir"
    }
  }
}
